# App/runtime

APP_ENV=development
LOG_LEVEL=INFO

# Database

DATABASE_URL=sqlite:///./saloon.db
AUTO_CREATE_TABLES=true

# Public URLs / CORS

PUBLIC_FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
BACKEND_API_URL=http://127.0.0.1:8000

# Booking / security

CLIENT_MANAGE_CUTOFF_HOURS=12
RATE_LIMIT_ENABLED=true

# -------------------------------------------------------------------
# AI Assistant
# -------------------------------------------------------------------
# AI is optional. If the provider is unavailable, the core booking
# system still works normally.
# AI does not directly access database, payments, webhooks, refunds,
# or admin logic. Real booking/payment actions remain backend-controlled.

AI_ENABLED=true

# Provider options: gemini | groq
AI_PROVIDER=groq

# Gemini provider
# Get a key from Google AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq provider
# Get a key from GroqCloud.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional demo safety limit for the AI assistant endpoint.
AI_DAILY_REQUEST_LIMIT=50

# Stripe

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email / Resend

RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Saloon Booking

# Telegram bot

TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_SOURCE=db
TELEGRAM_MANAGER_IDS=
TELEGRAM_BARBER_MASTER_MAP=
BOT_TIMEZONE=Europe/Vilnius
BARBER_REMINDER_MINUTES=15
BARBER_REMINDER_CHECK_INTERVAL_SECONDS=60

# Admin auth

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_EXPIRE_MINUTES=1440
