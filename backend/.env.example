# App/runtime
APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./saloon.db
# Demo/local convenience until migrations are added. Set false when managing schema separately.
AUTO_CREATE_TABLES=true

# Public URLs / CORS
PUBLIC_FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email / Resend API
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Saloon Booking

# Telegram bot
TELEGRAM_BOT_TOKEN=
BACKEND_API_URL=http://127.0.0.1:8000
TELEGRAM_AUTH_SOURCE=db

# Barber reminder
BOT_TIMEZONE=Europe/Vilnius
BARBER_REMINDER_MINUTES=15
BARBER_REMINDER_CHECK_INTERVAL_SECONDS=60

# Admin auth
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_EXPIRE_MINUTES=1440

# Legacy optional env auth fallback only, if supported:
# TELEGRAM_MANAGER_IDS=
# TELEGRAM_BARBER_MASTER_MAP=
