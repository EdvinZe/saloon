# App/runtime

APP_ENV=development
LOG_LEVEL=INFO

# Database

DATABASE_URL=sqlite:///./saloon.db
AUTO_CREATE_TABLES=true

# Public URLs / CORS

PUBLIC_FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
BACKEND_API_URL=http://127.0.0.1:8000

# Booking / security

CLIENT_MANAGE_CUTOFF_HOURS=12
RATE_LIMIT_ENABLED=true

# AI

AI_ENABLED=true
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_MAX_OUTPUT_TOKENS=350
AI_TEMPERATURE=0.2
AI_REQUEST_TIMEOUT_SECONDS=20
AI_DAILY_REQUEST_LIMIT=50

# Gemini

GEMINI_API_KEY=

# Stripe

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email / Resend

RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Saloon Booking

# Telegram bot

TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_SOURCE=db
TELEGRAM_MANAGER_IDS=
TELEGRAM_BARBER_MASTER_MAP=
BOT_TIMEZONE=Europe/Vilnius
BARBER_REMINDER_MINUTES=15
BARBER_REMINDER_CHECK_INTERVAL_SECONDS=60

# Admin auth

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_EXPIRE_MINUTES=1440
